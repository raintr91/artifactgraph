{
  "version": 1,
  "description": "Example workspace map — copy/adapt; SSOT lives in artifactgraph/platform-repos.json",
  "workspaceRoot": "..",
  "defaultGroup": "platform-bases",
  "harness": {
    "defaultByRole": {
      "frontend": "full",
      "client": "full",
      "backend": "shared",
      "fullstack": "full",
      "docs": "docs",
      "tests": "tests",
      "tooling": "tooling"
    },
    "syncPolicy": {
      "mode": "propose",
      "description": "Resolve profile per project → compare .cursor/skills to profiles.*.skills; propose add/remove. Do not bulk-sync all lanes."
    },
    "profiles": {
      "full": {
        "groups": ["code-fe", "code-fullstack"],
        "skills": [
          "platform-ai",
          "platform-base",
          "platform-mark",
          "artifactgraph",
          "prototype",
          "grill-prototype",
          "api",
          "grill-api",
          "wire",
          "test",
          "grill-test",
          "unit",
          "grill-unit",
          "model"
        ],
        "note": "FE + monorepo — DNA + code lane"
      },
      "shared": {
        "groups": ["code-be"],
        "skills": [
          "platform-ai",
          "platform-base",
          "platform-mark",
          "artifactgraph",
          "api",
          "grill-api",
          "wire",
          "unit",
          "grill-unit"
        ],
        "note": "BE only — DNA + api / wire / unit"
      },
      "docs": {
        "groups": ["docs"],
        "skills": [
          "platform-ai",
          "platform-mark",
          "artifactgraph",
          "spec",
          "legacy-spec",
          "update-spec",
          "update-spec-legacy",
          "bqa-grill-docs",
          "dev-grill-docs",
          "grill-with-docs",
          "dynamics",
          "flow-trace"
        ],
        "note": "base-docs hub"
      },
      "tests": {
        "groups": ["tests"],
        "skills": [
          "platform-ai",
          "platform-mark",
          "artifactgraph",
          "testcase",
          "grill-testcase"
        ],
        "note": "base-tests hub"
      },
      "tooling": {
        "groups": ["mcp"],
        "skills": ["platform-ai", "platform-mark", "artifactgraph"],
        "note": "MCP packages only"
      }
    }
  },
  "groups": {
    "platform-bases": {
      "description": "Full cluster — not a harness sync target",
      "primary": "portal",
      "projects": [
        "portal",
        "nextjs",
        "nuxt-nest",
        "next-nest",
        "fast-api-base",
        "api",
        "integration",
        "line",
        "base-docs",
        "base-tests",
        "artifactgraph",
        "hubdocs"
      ]
    },
    "code-fe": {
      "description": "FE — portal, nextjs, line (profile full)",
      "primary": "portal",
      "projects": ["portal", "nextjs", "line"]
    },
    "code-be": {
      "description": "BE — api, fast-api-base, integration (profile shared)",
      "primary": "api",
      "projects": ["api", "fast-api-base", "integration"]
    },
    "code-fullstack": {
      "description": "Monorepo FE+BE (profile full)",
      "primary": "nuxt-nest",
      "projects": ["nuxt-nest", "next-nest"]
    },
    "docs": {
      "description": "Docs hub (profile docs)",
      "primary": "base-docs",
      "projects": ["base-docs"]
    },
    "tests": {
      "description": "E2E plans hub (profile tests)",
      "primary": "base-tests",
      "projects": ["base-tests"]
    },
    "mcp": {
      "description": "MCP tooling (profile tooling)",
      "primary": "artifactgraph",
      "projects": ["artifactgraph", "hubdocs"]
    },
    "nuxt-nest-stack": {
      "description": "Nuxt 4 FE + NestJS BE (monorepo)",
      "primary": "nuxt-nest-fe",
      "projects": ["nuxt-nest-fe", "nuxt-nest-be"],
      "contract": {
        "frontend": "nuxt-nest-fe",
        "backend": "nuxt-nest-be",
        "sourceOfTruth": "docs-features-ir-spec"
      }
    },
    "next-nest-stack": {
      "description": "Next.js FE + NestJS BE (monorepo)",
      "primary": "next-nest-fe",
      "projects": ["next-nest-fe", "next-nest-be"],
      "contract": {
        "frontend": "next-nest-fe",
        "backend": "next-nest-be",
        "sourceOfTruth": "docs-features-ir-spec"
      }
    }
  },
  "projects": {
    "portal": {
      "root": ".",
      "role": "frontend",
      "stack": "nuxt4",
      "repo": "portal",
      "skill": "platform-base",
      "description": "Base Nuxt 4 (FE)",
      "write": true
    },
    "nextjs": {
      "root": "../nextjs",
      "role": "frontend",
      "stack": "nextjs",
      "repo": "nextjs",
      "skill": "platform-base",
      "description": "Base Next.js (FE)",
      "write": true
    },
    "nuxt-nest": {
      "root": "../nuxt_nest",
      "role": "fullstack",
      "stack": "nuxt4-nest",
      "repo": "nuxt_nest",
      "skill": "platform-base",
      "description": "Base Nuxt 4 + NestJS monorepo",
      "write": true
    },
    "next-nest": {
      "root": "../next_nest",
      "role": "fullstack",
      "stack": "nextjs-nest",
      "repo": "next_nest",
      "skill": "platform-base",
      "description": "Base Next.js + NestJS monorepo",
      "write": true
    },
    "fast-api-base": {
      "root": "../fast-api-base",
      "role": "backend",
      "stack": "fastapi",
      "repo": "fast-api-base",
      "skill": "platform-base",
      "description": "Base FastAPI (BE)",
      "write": true
    },
    "api": {
      "root": "../api",
      "role": "backend",
      "stack": "laravel",
      "repo": "api",
      "skill": "api-base",
      "description": "Base Laravel 12 (BE)",
      "write": true
    },
    "integration": {
      "root": "../integration",
      "role": "backend",
      "stack": "dotnet-integration",
      "repo": "integration",
      "skill": "platform-base",
      "description": "Base .NET (BE)",
      "write": true
    },
    "line": {
      "root": "../line",
      "role": "client",
      "stack": "dotnet-line",
      "repo": "line",
      "skill": "platform-base",
      "description": "Base WinForms — override in platform-repos.local.json for D:/workspace/line",
      "write": true
    },
    "base-docs": {
      "root": "../base-docs",
      "role": "docs",
      "stack": "docs-c4",
      "repo": "base-docs",
      "skill": "platform-ai",
      "description": "Base docs hub (R2) — C4 + product Code/common",
      "write": true,
      "specRoots": {
        "architecture": "architecture",
        "components": "product/components",
        "common": "product/common/code",
        "shared": "product/shared"
      },
      "docsSite": {
        "dev": "pnpm docs:dev",
        "root": "."
      }
    },
    "base-tests": {
      "root": "../base-tests",
      "role": "tests",
      "stack": "e2e-plans",
      "repo": "base-tests",
      "skill": "platform-ai",
      "description": "Base tests hub (R3) — E2E yaml/md plans only",
      "write": true,
      "testRoots": {
        "landscape": "landscape",
        "scenarios": "scenarios",
        "cases": "cases",
        "suites": "suites"
      }
    },
    "artifactgraph": {
      "root": "../artifactgraph",
      "role": "tooling",
      "stack": "mcp",
      "repo": "artifactgraph",
      "skill": "platform-ai",
      "harnessProfile": "tooling",
      "description": "Local MCP artifactgraph — gaps/tags/gen allowlist (raintr91/artifactgraph)",
      "write": true
    },
    "hubdocs": {
      "root": "../hubdocs",
      "role": "tooling",
      "stack": "mcp-docs",
      "repo": "hubdocs",
      "skill": "platform-ai",
      "harnessProfile": "tooling",
      "description": "MCP hubdocs — docs index / hub tooling (optional sibling repo)",
      "write": true
    },
    "nuxt-nest-fe": {
      "root": "../nuxt_nest",
      "role": "frontend",
      "stack": "nuxt4",
      "repo": "nuxt_nest",
      "skill": "platform-base",
      "write": true
    },
    "nuxt-nest-be": {
      "root": "../nuxt_nest/apps/api",
      "role": "backend",
      "stack": "nestjs",
      "repo": "nuxt_nest",
      "skill": "platform-base",
      "write": true
    },
    "next-nest-fe": {
      "root": "../next_nest",
      "role": "frontend",
      "stack": "nextjs",
      "repo": "next_nest",
      "skill": "platform-base",
      "write": true
    },
    "next-nest-be": {
      "root": "../next_nest/server",
      "role": "backend",
      "stack": "nestjs",
      "repo": "next_nest",
      "skill": "platform-base",
      "write": true
    }
  }
}
