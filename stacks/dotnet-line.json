{
  "stack": "dotnet-line",
  "mode": "brownfield",
  "commands": {
    "genDry": [
      "./codegen/runners/generate",
      "dry",
      "--id",
      "{spec}"
    ],
    "registryValidate": [
      "./codegen/runners/generate",
      "registry"
    ]
  },
  "registries": [
    "registries/codegen.registry.json"
  ],
  "gapSources": [
    "**/generated/HANDOFF.md",
    "**/generated/UNIT-HANDOFF.md",
    "**/generated/codegen.manifest.json"
  ],
  "specRoots": [],
  "templates": {
    "root": "codegen/templates",
    "engine": "scriban"
  },
  "dsl": {
    "ssot": "product-repo",
    "lanes": {
      "be": {
        "registries": [
          "registries/codegen.registry.json"
        ],
        "genKeys": [
          "genDry"
        ],
        "needsTags": [
          "#needs-endpoint",
          "#needs-dto"
        ],
        "note": "WinForms/client codegen — MCP indexes only"
      }
    }
  },
  "vocabularies": {
    "registryTags": "artifactgraph/lexicon/registry-tags.en.txt"
  }
}
