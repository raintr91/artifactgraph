{
  "stack": "dotnet-line",
  "mode": "brownfield",
  "commands": {
    "genDry": [
      "codegenkit",
      "gen:dry",
      "--adapter=dotnet-line",
      "--",
      "--spec",
      "{spec}"
    ],
    "gen": [
      "codegenkit",
      "gen",
      "--adapter=dotnet-line",
      "--",
      "--spec",
      "{spec}"
    ],
    "registryValidate": [
      "codegenkit",
      "registry",
      "--adapter=dotnet-line"
    ]
  },
  "registries": [
    "registries/dotnet-line.codegen.registry.json",
    "registries/codegen.registry.json"
  ],
  "gapSources": [
    "**/generated/HANDOFF.md",
    "**/generated/UNIT-HANDOFF.md",
    "**/generated/codegen.manifest.json"
  ],
  "specRoots": [],
  "templates": {
    "root": "adapters/dotnet-line/codegen",
    "engine": "scriban",
    "note": "SSOT in Codegenkit; product has no root codegen/"
  },
  "dsl": {
    "ssot": "product-repo",
    "lanes": {
      "fe": {
        "registries": [
          "registries/dotnet-line.codegen.registry.json"
        ],
        "genKeys": [
          "genDry",
          "gen"
        ],
        "needsTags": [
          "#needs-shell",
          "#needs-widget"
        ],
        "note": "WinForms/kiosk client — Codegenkit CLI; MCP indexes only"
      }
    }
  },
  "vocabularies": {
    "registryTags": "artifactgraph/lexicon/registry-tags.en.txt"
  }
}
