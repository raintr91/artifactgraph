{
  "stack": "fastapi",
  "mode": "brownfield",
  "commands": {
    "genDry": [
      "./codegen/runners/generate",
      "dry",
      "--id",
      "{spec}"
    ],
    "gen": [
      "./codegen/runners/generate",
      "write",
      "--id",
      "{spec}"
    ],
    "registryValidate": [
      "./codegen/runners/generate",
      "registry"
    ],
    "commonRegistry": [
      "./registries/validate-common",
      "validate"
    ]
  },
  "registries": [
    "registries/codegen.registry.json",
    "registries/unit-test.registry.json",
    "registries/common.registry.json"
  ],
  "gapSources": [
    "**/generated/HANDOFF.md",
    "**/generated/UNIT-HANDOFF.md",
    "**/generated/codegen.manifest.json"
  ],
  "specRoots": [],
  "templates": {
    "root": "codegen/templates",
    "engine": "jinja2"
  },
  "dsl": {
    "ssot": "product-repo",
    "lanes": {
      "be": {
        "registries": [
          "registries/codegen.registry.json",
          "registries/common.registry.json"
        ],
        "genKeys": [
          "genDry",
          "gen"
        ],
        "needsTags": [
          "#needs-endpoint",
          "#needs-dto"
        ],
        "note": "BE registry + templates stay in product repo; MCP indexes only"
      },
      "unit": {
        "registries": [
          "registries/unit-test.registry.json"
        ],
        "genKeys": [],
        "needsTags": [
          "#needs-unit-test"
        ]
      }
    }
  },
  "vocabularies": {
    "registryTags": "artifactgraph/lexicon/registry-tags.en.txt"
  }
}
