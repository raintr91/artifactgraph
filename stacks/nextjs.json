{
  "stack": "nextjs",
  "mode": "brownfield",
  "commands": {
    "docsRender": [
      "pnpm",
      "--dir",
      "@base-docs",
      "docs:render"
    ],
    "specSplit": [
      "pnpm",
      "--dir",
      "@base-docs",
      "spec:split",
      "--",
      "{spec}"
    ],
    "specSplitAll": [
      "pnpm",
      "--dir",
      "@base-docs",
      "spec:split:all"
    ],
    "genDry": [
      "pnpm",
      "portal:gen:dry",
      "--id",
      "{spec}"
    ],
    "gen": [
      "pnpm",
      "portal:gen",
      "--id",
      "{spec}"
    ],
    "unitGenDry": [
      "pnpm",
      "portal:unit-gen:dry",
      "--spec",
      "{spec}"
    ],
    "unitGen": [
      "pnpm",
      "portal:unit-gen",
      "--spec",
      "{spec}"
    ],
    "testcaseGenDry": [
      "pnpm",
      "testcase:gen:dry",
      "--id",
      "{spec}"
    ],
    "testcaseGen": [
      "pnpm",
      "testcase:gen",
      "--id",
      "{spec}"
    ],
    "contractGenDry": [
      "pnpm",
      "contract:gen:dry",
      "--spec",
      "{spec}"
    ],
    "registryValidate": [
      "pnpm",
      "portal:registry"
    ],
    "contractRegistry": [
      "pnpm",
      "contract:registry"
    ]
  },
  "registries": [
    "registries/design.registry.json",
    "registries/unit-test.registry.json",
    "registries/e2e-test.registry.json",
    "registries/contract-field.registry.json"
  ],
  "gapSources": [
    "@base-docs/product/**/generated/HANDOFF.md",
    "@base-docs/product/**/generated/UNIT-HANDOFF.md",
    "@base-docs/product/**/generated/codegen.manifest.json",
    "**/generated/HANDOFF.md",
    "**/generated/UNIT-HANDOFF.md",
    "**/generated/codegen.manifest.json"
  ],
  "specRoots": [
    "@base-docs/product",
    "@base-tests/cases",
    "@base-tests/suites"
  ],
  "templates": {
    "root": "codegen/templates",
    "engine": "hbs"
  },
  "dsl": {
    "ssot": "product-repo",
    "lanes": {
      "docs": {
        "genKeys": [
          "specSplit",
          "specSplitAll",
          "docsRender"
        ],
        "note": "Tag reuse + split/render; no app codegen in spec phase"
      },
      "fe": {
        "registries": [
          "registries/design.registry.json"
        ],
        "genKeys": [
          "genDry",
          "gen"
        ],
        "needsTags": [
          "#needs-component",
          "#needs-ui"
        ]
      },
      "unit": {
        "registries": [
          "registries/unit-test.registry.json"
        ],
        "genKeys": [
          "unitGenDry",
          "unitGen"
        ],
        "needsTags": [
          "#needs-unit-test"
        ]
      },
      "e2e": {
        "registries": [
          "registries/e2e-test.registry.json"
        ],
        "genKeys": [
          "testcaseGenDry",
          "testcaseGen"
        ],
        "needsTags": [
          "#needs-testcase",
          "#needs-e2e"
        ],
        "note": "{spec} = hub id (W-|TC-|CMP-|suite) for --id"
      }
    }
  },
  "hubs": {
    "docs": "base-docs",
    "tests": "base-tests"
  },
  "vocabularies": {
    "registryTags": "@base-docs/platform/toolchain/lexicon/registry-tags.en.txt",
    "testTaxonomy": "@base-tests/catalog/lexicon/testcase-taxonomy.en.txt"
  }
}
