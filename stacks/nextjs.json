{
  "stack": "nextjs",
  "mode": "brownfield",
  "commands": {
    "genDry": ["pnpm", "portal:gen:dry", "--spec", "{spec}"],
    "gen": ["pnpm", "portal:gen", "--spec", "{spec}"],
    "unitGenDry": ["pnpm", "portal:unit-gen:dry", "--spec", "{spec}"],
    "contractGenDry": ["pnpm", "contract:gen:dry", "--spec", "{spec}"],
    "registryValidate": ["pnpm", "portal:registry"],
    "contractRegistry": ["pnpm", "contract:registry"]
  },
  "registries": [
    "registries/design.registry.json",
    "registries/unit-test.registry.json",
    "registries/e2e-test.registry.json",
    "registries/contract-field.registry.json"
  ],
  "gapSources": ["**/generated/HANDOFF.md", "**/generated/codegen.manifest.json"],
  "specRoots": ["docs/features/yaml"],
  "templates": { "root": "codegen/templates", "engine": "hbs" }
}
