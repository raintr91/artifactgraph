{
  "stack": "nuxt4",
  "mode": "brownfield",
  "commands": {
    "genDry": ["pnpm", "portal:gen:dry", "--spec", "{spec}"],
    "gen": ["pnpm", "portal:gen", "--spec", "{spec}"],
    "unitGenDry": ["pnpm", "portal:unit-gen:dry", "--spec", "{spec}"],
    "unitGen": ["pnpm", "portal:unit-gen", "--spec", "{spec}"],
    "testcaseGenDry": ["pnpm", "testcase:gen:dry", "--", "{spec}"],
    "registryValidate": ["pnpm", "portal:registry"],
    "unitRegistry": ["pnpm", "portal:unit-registry"],
    "e2eRegistry": ["pnpm", "portal:e2e-registry"],
    "commonRegistry": ["pnpm", "platform-common:registry"]
  },
  "registries": [
    "registries/design.registry.json",
    "registries/common.registry.json",
    "registries/unit-test.registry.json",
    "registries/e2e-test.registry.json",
    "registries/page-lifecycle.registry.json"
  ],
  "gapSources": [
    "**/generated/HANDOFF.md",
    "**/generated/UNIT-HANDOFF.md",
    "**/generated/codegen.manifest.json"
  ],
  "specRoots": ["docs/features/yaml", "docs/common/yaml"],
  "templates": { "root": "codegen/templates", "engine": "hbs" }
}
