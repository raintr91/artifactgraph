{
  "stack": "nuxt4",
  "mode": "brownfield",
  "commands": {
    "genDry": [
      "codegenkit",
      "gen:dry",
      "--adapter=nuxt4",
      "--",
      "--id",
      "{spec}"
    ],
    "gen": [
      "codegenkit",
      "gen",
      "--adapter=nuxt4",
      "--",
      "--id",
      "{spec}"
    ],
    "unitGenDry": [
      "codegenkit",
      "unit-gen:dry",
      "--adapter=nuxt4",
      "--",
      "--id",
      "{spec}"
    ],
    "unitGen": [
      "codegenkit",
      "unit-gen",
      "--adapter=nuxt4",
      "--",
      "--id",
      "{spec}"
    ],
    "testcaseGenDry": [
      "testkit",
      "testcase:gen:dry",
      "--",
      "--id",
      "{spec}"
    ],
    "testcaseGen": [
      "testkit",
      "testcase:gen",
      "--",
      "--id",
      "{spec}"
    ],
    "registryValidate": [
      "codegenkit",
      "registry",
      "--adapter=nuxt4"
    ],
    "unitRegistry": [
      "codegenkit",
      "unit-registry",
      "--adapter=nuxt4"
    ],
    "e2eRegistry": [
      "testkit",
      "e2e-registry"
    ],
    "commonRegistry": [
      "codegenkit",
      "common-registry"
    ]
  },
  "registries": [
    "registries/design.registry.json",
    "registries/common.registry.json",
    "registries/unit-test.registry.json",
    "registries/e2e-test.registry.json",
    "registries/page-lifecycle.registry.json"
  ],
  "gapSources": [
    "**/generated/HANDOFF.md",
    "**/generated/UNIT-HANDOFF.md",
    "**/generated/codegen.manifest.json"
  ],
  "specRoots": [],
  "templates": {
    "root": "adapters/nuxt4/codegen/templates",
    "engine": "hbs",
    "note": "SSOT in Codegenkit; product has no root codegen/"
  },
  "dsl": {
    "ssot": "product-repo",
    "lanes": {
      "fe": {
        "registries": [
          "registries/design.registry.json",
          "registries/common.registry.json"
        ],
        "genKeys": [
          "genDry",
          "gen"
        ],
        "needsTags": [
          "#needs-component",
          "#needs-ui",
          "#shell:",
          "#widget:"
        ],
        "note": "Review OK → promote design/common registry in product repo; rebuild index"
      },
      "unit": {
        "registries": [
          "registries/unit-test.registry.json"
        ],
        "genKeys": [
          "unitGenDry",
          "unitGen"
        ],
        "needsTags": [
          "#needs-unit-test"
        ],
        "note": "Promote unit-test.registry.json after pattern OK"
      },
      "e2e": {
        "registries": [
          "registries/e2e-test.registry.json"
        ],
        "genKeys": [
          "testcaseGenDry",
          "testcaseGen"
        ],
        "needsTags": [
          "#needs-testcase",
          "#needs-e2e"
        ],
        "note": "{spec} = hub id (W-|TC-|CMP-|suite) for --id"
      },
      "lifecycle": {
        "registries": [
          "registries/page-lifecycle.registry.json"
        ],
        "genKeys": [],
        "needsTags": [],
        "note": "Updated by codegenkit gen; no separate lifecycle CLI"
      }
    }
  },
  "vocabularies": {
    "registryTags": "artifactgraph/lexicon/registry-tags.en.txt"
  }
}
