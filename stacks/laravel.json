{
  "stack": "laravel",
  "mode": "brownfield",
  "commands": {
    "genDry": [
      "pnpm",
      "api:gen:dry",
      "--id",
      "{spec}"
    ],
    "gen": [
      "pnpm",
      "api:gen",
      "--id",
      "{spec}"
    ],
    "unitGenDry": [
      "pnpm",
      "api:unit-gen:dry",
      "--spec",
      "{spec}"
    ],
    "unitGen": [
      "pnpm",
      "api:unit-gen",
      "--spec",
      "{spec}"
    ],
    "registryValidate": [
      "pnpm",
      "api:registry"
    ]
  },
  "registries": [
    "registries/codegen.registry.json",
    "registries/unit-test.registry.json"
  ],
  "gapSources": [
    "**/generated/HANDOFF.md",
    "**/generated/UNIT-HANDOFF.md",
    "**/generated/codegen.manifest.json"
  ],
  "specRoots": [],
  "templates": {
    "root": "unitgen/templates",
    "engine": "hbs"
  },
  "dsl": {
    "ssot": "product-repo",
    "lanes": {
      "be": {
        "registries": [
          "registries/codegen.registry.json"
        ],
        "genKeys": [
          "genDry",
          "gen"
        ],
        "needsTags": [
          "#needs-endpoint",
          "#needs-dto"
        ],
        "note": "BE registry + templates stay in api repo; MCP indexes only"
      },
      "unit": {
        "registries": [
          "registries/unit-test.registry.json"
        ],
        "genKeys": [
          "unitGenDry",
          "unitGen"
        ],
        "needsTags": [
          "#needs-unit-test"
        ]
      }
    }
  },
  "vocabularies": {
    "registryTags": "artifactgraph/lexicon/registry-tags.en.txt"
  }
}
