{
  "name": "@platform/artifactgraph",
  "version": "2.2.2",
  "description": "Standalone local MCP for artifact registries, gaps, tag suggestions, and allowlisted codegen",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "artifactgraph": "./bin/artifactgraph.mjs",
    "artifactgraph-mcp": "./bin/artifactgraph-mcp.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raintr91/artifactgraph.git"
  },
  "homepage": "https://github.com/raintr91/artifactgraph#readme",
  "bugs": {
    "url": "https://github.com/raintr91/artifactgraph/issues"
  },
  "files": [
    "bin",
    "dist",
    "stacks",
    "lexicon",
    "harness",
    "docs",
    "examples",
    "install.sh",
    "install.ps1",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.mjs",
    "harness:export": "node scripts/export-cursor-harness.mjs",
    "prepare": "npm run build",
    "mcp": "node bin/artifactgraph-mcp.mjs",
    "cli": "node bin/artifactgraph.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "mcp",
    "codegen",
    "platform",
    "artifactgraph"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}